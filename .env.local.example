# Required: pooled Neon connection string for app runtime reads.
DATABASE_URL="postgres://user:password@host/database?sslmode=require"

# Required: unpooled Neon connection string for migrations and seeding.
DATABASE_URL_UNPOOLED="postgres://user:password@host/database?sslmode=require"

# Optional: enables successful AI Overview responses.
# Core recipe browsing works without this value.
AI_GATEWAY_API_KEY=""
